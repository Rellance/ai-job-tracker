# ─────────────────────────────────────────────────────────────
#  AI Job Tracker — environment variables
#  Copy to .env and fill in. Validated at boot by src/lib/env.ts.
# ─────────────────────────────────────────────────────────────

# Core (required) -------------------------------------------------
# Postgres connection. App uses the pooled URL; migrations use DIRECT_URL.
# Supabase: DATABASE_URL = Transaction pooler (port 6543), DIRECT_URL = Direct (5432).
# Neon/local: DIRECT_URL can equal DATABASE_URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"
# Auth.js — generate with: openssl rand -base64 32 (set both to the same value)
NEXTAUTH_SECRET="replace-me"
AUTH_SECRET="replace-me"
AUTH_TRUST_HOST="true"
NEXTAUTH_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# Background jobs — Redis (Upstash rediss:// URL) ----------------- [M1/M4]
REDIS_URL=""

# AI (OpenAI) ---------------------------------------------------- [M4]
OPENAI_API_KEY=""

# Billing (Stripe, test-mode) ------------------------------------ [M5]
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_ENTERPRISE=""

# Email (Resend; dev logs to console) ---------------------------- [M1]
RESEND_API_KEY=""
EMAIL_FROM="AI Job Tracker <noreply@aijobtracker.dev>"

# File storage (Cloudflare R2; dev falls back to local disk) ----- [M4]
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_URL=""

# Observability (Sentry) ----------------------------------------- [M5]
SENTRY_DSN=""
